# Copy to .env and fill in. Never commit .env.

# Ollama Cloud (OpenAI-compatible). Get the key from your ollama.com account.
OLLAMA_API_KEY=your_ollama_key
OLLAMA_BASE_URL=https://ollama.com/v1
MODEL=glm-5.2:cloud

# Brave Search API (metered pay-as-you-go; payment method required even for free credits)
BRAVE_API_KEY=your_brave_key
# News recency: Brave's freshness filter is loose, so results are also hard-filtered by page age.
BRAVE_FRESHNESS=pw          # pd=24h, pw=past week, pm=past month, py=past year
BRAVE_MAX_AGE_DAYS=30       # drop dated results older than this many days

# Optional: LOCAL model (Llama 3.2 via Ollama) powers two fail-open helpers —
#   STRUCT_CHECK: independent structural review of equity reports
#   RESOLVER_LLM: infers instrument type from free-text queries ("Nifty IT", "tech sector")
# Both degrade gracefully if the local model is offline. Set either to 0 to disable.
STRUCT_CHECK=1
RESOLVER_LLM=1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
LOCAL_MODEL=llama3.2

# Optional: persist each run's report + facts to RUNS_DIR (default ./runs). Set SAVE_RUNS=0 to disable.
SAVE_RUNS=1
# RUNS_DIR=runs

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_botfather_token

# Comma-separated Telegram user ids and/or group chat ids (negative for groups)
# allowed to use the bot. Get your id from @userinfobot.
ALLOWED_IDS=123456789
