# Copy to .env and fill in. Never commit .env (it is gitignored).
#   cp .env.example .env

# ── Ollama (GLM-5.2, the orchestrating model) ──────────────────────────────
# Cloud route (recommended): get the key from your ollama.com account.
OLLAMA_API_KEY=your_ollama_key
OLLAMA_BASE_URL=https://ollama.com/v1
MODEL=glm-5.2
# Local route alternative (a signed-in `ollama serve` proxying to cloud):
#   OLLAMA_BASE_URL=http://localhost:11434/v1
#   OLLAMA_API_KEY=ollama
#   MODEL=glm-5.2:cloud

# ── Brave Search (news / instrument discovery) ─────────────────────────────
# Metered pay-as-you-go; a payment method is required even within free credits.
BRAVE_API_KEY=your_brave_key
# News recency: Brave's freshness filter is loose, so results are also hard-filtered by age.
BRAVE_FRESHNESS=pw          # pd=24h, pw=past week, pm=past month, py=past year
BRAVE_MAX_AGE_DAYS=30       # drop dated results older than this many days

# ── Telegram ───────────────────────────────────────────────────────────────
# Bot token from @BotFather.
TELEGRAM_TOKEN=your_botfather_token
# Comma-separated Telegram user ids and/or group chat ids (negative for groups)
# allowed to use the bot. Get your id from @userinfobot.
ALLOWED_IDS=123456789

# ── Local helper LLM (Llama 3.2 via Ollama) ────────────────────────────────
# Powers two fail-open helpers: RESOLVER_LLM (free-text -> instrument intent) and
# STRUCT_CHECK (independent structural review of equity reports). Both degrade
# gracefully if the local model is offline. Set either to 0 to disable.
RESOLVER_LLM=1
STRUCT_CHECK=1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
LOCAL_MODEL=llama3.2

# ── Output ─────────────────────────────────────────────────────────────────
# Persist each run's report + facts to RUNS_DIR (default ./runs). Set SAVE_RUNS=0 to disable.
SAVE_RUNS=1
# RUNS_DIR=runs
# Deliver the report as a dated PDF (default on). Set REPORT_PDF=0 for text-only.
REPORT_PDF=1
# REPORTS_DIR=reports
